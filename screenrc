startup_message off
vbell off
nethack on
autodetach on
defscrollback 2500
msgminwait 0
msgwait 10
activity Activity in window %n
sessionname main
hardcopy_append on
#idle 3600 lockscreen
#password /RohmJabCdrXU
#escape ^Tt
shell -/bin/zsh
shelltitle shell

caption always
caption string "%{= bw} %H [%t] %h %= %D %M %d %C%a  "
hardstatus off
hardstatus alwayslastline
hardstatus string "%-Lw%{= bw}%50>%n%f* %t%{-}%+Lw%<"

bind ^e screen -t email 0 mutt

#chdir /path...
#screen -t mutt 0 mutt
screen -t shell 1

